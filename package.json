{
  "name": "crownutils",
  "version": "0.4.1",
  "description": "A Discord bot",
  "main": "dist/index.js",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "build": "tsc && tsc-alias",
    "start": "NODE_ENV=production node --env-file-if-exists=.env dist/index.js",
    "dev": "NODE_ENV=development tsx watch --env-file=.env src/index.ts",
    "deploy": "NODE_ENV=development tsx --env-file=.env src/deploy-commands.ts",
    "deploy:prod": "NODE_ENV=production tsx --env-file=.env src/deploy-commands.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "postinstall": "prisma generate"
  },
  "keywords": [],
  "author": "",
  "license": "PolyForm-Noncommercial-1.0.0",
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "discord.js": "^14.26.4",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  }
}
