generator client {
  provider = "prisma-client"
  output   = "../src/core/persistence/prisma"
}

datasource db {
  provider = "sqlite"
}

model Reminder {
  id        String   @id @default(cuid())
  channelId String
  userId    String
  triggerAt DateTime
  message   String
}

// Singleton row (id always 1) holding bot-wide toggles.
model BotState {
  id                 Int     @id @default(1)
  maintenanceEnabled Boolean @default(false)
}
