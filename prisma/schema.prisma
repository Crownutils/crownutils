generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model BotState {
  id Int @id @default(1)
  maintenanceEnabled Boolean @default(false)
}

enum Language {
  fr
  en
}

model User {
  userId String @id
  pseudoId String @unique @default(uuid())
  language Language @default(en)
}
