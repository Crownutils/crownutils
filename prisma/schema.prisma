generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model BotState {
  id                 Int     @id @default(1)
  maintenanceEnabled Boolean @default(false)
}

enum Language {
  fr
  en
}

enum Rank {
  banned
  normal
  privileged
  owner
}

model User {
  userId   String   @id
  language Language @default(en)
  rank     Rank     @default(normal)
}

model LegalAcceptance {
  userId          String   @id
  acceptedVersion String
  acceptedAt      DateTime @default(now())
}

model Banned {
  hash String @id @unique
}

model GdprRequest {
  hash        String   @id
  requestedAt DateTime @default(now())
}

enum ReminderStatus {
  pending
  delivering
  delivered
  failed
}

model Reminder {
  id          String         @id @default(cuid())
  userId      String
  channelId   String
  content     String
  dueAt       DateTime
  durationMs  Int
  status      ReminderStatus @default(pending)
  attempts    Int            @default(0)
  lastError   String?
  createdAt   DateTime       @default(now())
  deliveredAt DateTime?

  // Scheduler next-due lookup and due-batch sweep filter status then order by dueAt.
  @@index([status, dueAt])
  // `reminders` list and per-user quota filter userId + active status.
  @@index([userId, status])
}
